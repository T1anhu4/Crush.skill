{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Memory Context",
  "type": "object",
  "properties": {
    "summary": {"type": "string"},
    "snippets": {
      "type": "array",
      "items": {"type": "string"}
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {},
          "score": {"type": "number"},
          "role": {"type": "string"},
          "content": {"type": "string"}
        },
        "required": ["id", "role", "content"]
      }
    }
  },
  "required": ["summary", "snippets"]
}
