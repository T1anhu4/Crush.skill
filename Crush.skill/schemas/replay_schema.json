{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Post Mortem Report",
  "type": "object",
  "properties": {
    "session_id": {"type": "string"},
    "diagnostics": {
      "type": "object",
      "properties": {
        "frame_collapses": {"type": "array"},
        "attraction_peaks": {"type": "array"},
        "defense_triggers": {"type": "array"}
      },
      "required": ["frame_collapses", "attraction_peaks", "defense_triggers"]
    },
    "timeline": {"type": "array"},
    "narrative": {"type": "string"}
  },
  "required": ["session_id", "diagnostics", "narrative"]
}
